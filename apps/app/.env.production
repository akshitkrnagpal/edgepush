# Where client-side API calls go (auth, dashboard mutations, etc.).
# Baked at build time by Next.js. NOT read at runtime.
#
# Points at the APP domain (same origin) so auth and dashboard calls
# go through the embedded Hono app. No CORS, no separate API worker
# needed. The SDK/CLI still call api.edgepush.dev for /v1/send.
#
# Self-hosters: set this to YOUR OWN DOMAIN (same origin).
#   Example: NEXT_PUBLIC_API_URL=https://push.yourcompany.com

NEXT_PUBLIC_API_URL=https://app.edgepush.dev
