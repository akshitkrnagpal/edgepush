{
  "name": "@edgepush/api",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "edgepush HTTP API (optional Hono worker for push hot path)",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply edgepush --local",
    "db:migrate:remote": "wrangler d1 migrations apply edgepush --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@edgepush/server": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "jose": "^6.2.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20260426.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
