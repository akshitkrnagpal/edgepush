{
  "name": "@edgepush/api",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "edgepush HTTP API (optional Hono worker for push hot path)",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply edgepush --local",
    "db:migrate:remote": "wrangler d1 migrations apply edgepush --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@edgepush/server": "workspace:*",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.19",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.6",
    "@cloudflare/workers-types": "^4.20260517.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }
}
