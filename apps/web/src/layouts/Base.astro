---
import "../styles/globals.css";

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  description?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title = "edgepush. Open source push notifications at the edge",
  description = "Open source push notifications for iOS and Android. One API on Cloudflare Workers, BYO APNs and FCM, encrypted at rest. Free hosted or self-host.",
  breadcrumbs,
} = Astro.props;

const siteUrl = "https://edgepush.dev";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}/og.png`;

const organizationNode = {
  "@type": "Organization",
  "@id": `${siteUrl}/#org`,
  name: "edgepush",
  url: siteUrl,
  logo: ogImage,
  sameAs: [
    "https://github.com/akshitkrnagpal/edgepush",
    "https://twitter.com/akshit_io",
  ],
};

const websiteNode = {
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  url: siteUrl,
  name: "edgepush",
  description,
  publisher: { "@id": `${siteUrl}/#org` },
};

const softwareAppNode = {
  "@type": "SoftwareApplication",
  "@id": `${siteUrl}/#app`,
  name: "edgepush",
  description,
  url: siteUrl,
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Cloud, iOS, Android",
  license: "https://www.gnu.org/licenses/agpl-3.0.html",
  codeRepository: "https://github.com/akshitkrnagpal/edgepush",
  publisher: { "@id": `${siteUrl}/#org` },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
    url: `${siteUrl}/pricing`,
    availability: "https://schema.org/InStock",
  },
};

const graph: Record<string, unknown>[] = [
  organizationNode,
  websiteNode,
  softwareAppNode,
];

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      item: new URL(b.url, siteUrl).href,
    })),
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts: async / non-render-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap"
    />
    <link
      rel="preload"
      as="style"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap"
      />
      <link
        rel="stylesheet"
        href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700,800&display=swap"
      />
    </noscript>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="edgepush" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@akshit_io" />
    <meta name="twitter:creator" content="@akshit_io" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-full flex flex-col bg-bg text-text">
    <slot />

    <!-- Ahrefs Analytics -->
    <script src="https://analytics.ahrefs.com/analytics.js" data-key="Tp++7dXsJK0nDTSq36LlkQ" async></script>

    <!-- PostHog Analytics -->
