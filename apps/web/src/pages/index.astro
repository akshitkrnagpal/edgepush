      <div class="overflow-x-auto border border-rule-strong bg-surface">
        <table class="w-full font-mono text-[12.5px]">
          <thead>
            <tr class="border-b border-rule-strong bg-[#111111] text-left text-[11px] uppercase tracking-[0.12em] text-muted-strong">
              <th class="px-5 py-3.5 font-medium"> </th>
              <th class="px-5 py-3.5 font-bold text-accent">edgepush</th>
              <th class="px-5 py-3.5 font-medium">expo push</th>
              <th class="px-5 py-3.5 font-medium">onesignal</th>
              <th class="px-5 py-3.5 font-medium">knock</th>
            </tr>
          </thead>
          <tbody class="text-muted-strong">
            {compareRows.map((row) => (
              <tr class="border-b border-rule last:border-b-0">
                <td class="px-5 py-3 text-text">{row.label}</td>
                {row.values.map((v, i) => {
                  const positive = isPositive(v);
                  const negative = isNegative(v);
                  return (
                    <td
                      class={`px-5 py-3 ${
                        i === 0 && positive
                          ? "text-success font-bold"
                          : negative
                            ? "text-error"
                            : "text-muted-strong"
                      }`}
                    >
                      {i === 0 && positive ? <span class="mr-1">●</span> : null}
                      {v}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 font-sans text-[12px] text-muted">
        Comparison reflects publicly documented pricing and features as of
        April 2026. Other providers may have changed; check their docs.
