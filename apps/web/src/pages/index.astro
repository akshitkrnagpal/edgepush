---
import Base from "../layouts/Base.astro";

// Helper types and functions (replacing React components with inline rendering)
type Tone = "" | "accent" | "text" | "muted" | "muted-strong";

function tone(t: Tone): string {
  if (t === "accent") return "text-accent";
  if (t === "text") return "text-text";
  if (t === "muted") return "text-muted";
  if (t === "muted-strong") return "text-muted-strong";
  return "";
}

interface LogLineProps {
  ts: string;
  app: string;
  id: string;
  status: "ok" | "warn" | "err" | "pend";
  label: string;
  meta: string;
}

const logLines: LogLineProps[] = [
  { ts: "2026-04-11T04:25:12.847Z", app: "io.acme.pos", id: "tk_01HX2A9P…4M", status: "ok", label: "delivered", meta: "192ms · apns · device_ios 17.4" },
  { ts: "2026-04-11T04:25:11.402Z", app: "app.orbit.ios", id: "tk_01HX2A9P…3K", status: "ok", label: "delivered", meta: "144ms · apns · device_ios 17.4" },
  { ts: "2026-04-11T04:25:10.219Z", app: "com.ridehaus.android", id: "tk_01HX2A9P…3J", status: "pend", label: "queued", meta: "- · fcm · device_android 14" },
  { ts: "2026-04-11T04:25:09.113Z", app: "io.acme.pos", id: "tk_01HX2A9P…3G", status: "warn", label: "retry 1/3", meta: "apns_rate_limit · backoff 2s" },
  { ts: "2026-04-11T04:25:07.005Z", app: "com.pixeldiner", id: "tk_01HX2A9P…3A", status: "err", label: "failed", meta: "invalid_token · auto-removed" },
  { ts: "2026-04-11T04:25:04.882Z", app: "app.orbit.ios", id: "tk_01HX2A9P…2Z", status: "ok", label: "delivered", meta: "210ms · apns · device_ios 17.4" },
];

function statusColor(status: string): string {
  if (status === "ok") return "text-success";
  if (status === "warn") return "text-warning";
  if (status === "err") return "text-error";
  return "text-muted";
}

function statusDot(status: string): string {
  return status === "pend" ? "○" : "●";
}

interface CodeLine {
  lines: Array<Array<[Tone, string]>>;
  tab: string;
  label: string;
}

const nodeTsPanel: CodeLine = {
  tab: "node.ts",
  label: "@edgepush/sdk",
  lines: [
    [["muted", "// npm install @edgepush/sdk"]],
    [["accent", "import"], ["", " "], ["muted-strong", "{ Edgepush }"], ["", " "], ["accent", "from"], ["", " "], ["text", '"@edgepush/sdk"'], ["", ";"]],
    [],
    [["accent", "const"], ["", " "], ["muted-strong", "client"], ["", " = "], ["accent", "new"], ["", " Edgepush({ "], ["muted-strong", "apiKey"], ["", ": "], ["text", '"com.acme.app|sk_…"'], ["", " });"]],
    [],
    [["accent", "await"], ["", " "], ["muted-strong", "client"], ["", ".send({"]],
    [["", "  "], ["muted-strong", "to"], ["", ":    "], ["text", '"a1b2c3d4…"'], ["", ","]],
    [["", "  "], ["muted-strong", "title"], ["", ": "], ["text", '"Hello"'], ["", ","]],
    [["", "  "], ["muted-strong", "body"], ["", ":  "], ["text", '"From Node"'], ["", ","]],
    [["", "});"]],
  ],
};

const curlPanel: CodeLine = {
  tab: "curl",
  label: "POST /v1/send",
  lines: [
    [["muted", "# any HTTP client works"]],
    [["text", "curl https://api.edgepush.dev/v1/send \\"]],
    [["", "  -H "], ["text", "\"authorization: Bearer com.acme.app|sk_…\""], ["", " \\"]],
    [["", "  -H "], ["text", "\"content-type: application/json\""], ["", " \\"]],
    [["", "  -d "], ["text", "'{"]],
    [["", "    "], ["text", "\"messages\": [{"]],
    [["", "      "], ["text", "\"to\": \"a1b2c3d4…\","]],
    [["", "      "], ["text", "\"title\": \"Hello\","]],
    [["", "      "], ["text", "\"body\": \"From curl\""]],
    [["", "    "], ["text", "}]"]],
    [["", "  "], ["text", "}'"]],
  ],
};

const webhookPanel: CodeLine = {
  tab: "POST /your/webhook",
  label: "● 200 OK",
  lines: [
    [["muted", "// headers"]],
    [["muted-strong", "x-edgepush-event"], ["", ":     "], ["text", "message.delivered"]],
    [["muted-strong", "x-edgepush-signature"], ["", ": "], ["text", "sha256=9f86d081…"]],
    [["muted-strong", "x-edgepush-id"], ["", ":        "], ["text", "evt_01HX2A9P4M"]],
    [],
    [["muted", "// body"]],
    [["text", "{"]],
    [["", "  "], ["text", "\"event\""], ["", ": "], ["text", "\"message.delivered\","]],
    [["", "  "], ["text", "\"id\""], ["", ":    "], ["text", "\"tk_01HX2A9P4M\","]],
    [["", "  "], ["text", "\"app\""], ["", ":   "], ["text", "\"com.acme.app\","]],
    [["", "  "], ["text", "\"to\""], ["", ":    "], ["text", "\"a1b2c3d4…\","]],
    [["", "  "], ["text", "\"platform\""], ["", ": "], ["text", "\"ios\","]],
    [["", "  "], ["text", "\"latency_ms\""], ["", ": "], ["text", "192"]],
    [["text", "}"]],
  ],
};

interface CompareRowData {
  label: string;
  values: [string, string, string, string];
}

const compareRows: CompareRowData[] = [
  { label: "open source", values: ["yes", "no", "no", "no"] },
  { label: "self-hostable", values: ["yes", "no", "no", "no"] },
  { label: "byo apns + fcm", values: ["yes", "no", "yes", "yes"] },
  { label: "native token format", values: ["yes", "no (proprietary)", "yes", "yes"] },
  { label: "rich notifications (images)", values: ["yes", "no", "yes", "yes"] },
  { label: "apns collapse-id", values: ["yes", "no", "yes", "yes"] },
  { label: "fine-grained apns push types (voip, location, ...)", values: ["yes", "no", "partial", "partial"] },
  { label: "reliable silent / background push", values: ["yes", "best effort", "yes", "yes"] },
  { label: "absolute notification expiration", values: ["yes", "no", "yes", "yes"] },
  { label: "delivery receipts + retries + dlq", values: ["yes", "best effort", "yes", "yes"] },
  { label: "fcm topic / condition targeting", values: ["yes", "no", "yes", "yes"] },
  { label: "webhook retry with backoff", values: ["yes (3x)", "no", "yes", "yes"] },
  { label: "hard rate ceiling", values: ["per-app, configurable", "600/sec global", "n/a", "n/a"] },
  { label: "runs on cloudflare workers", values: ["yes", "no", "no", "no"] },
  { label: "per-message pricing", values: ["no", "no (rate-limited)", "yes", "yes"] },
  { label: "vendor lock-in", values: ["none", "high", "medium", "medium"] },
  { label: "cost (10k pushes/mo)", values: ["$0", "$0", "≈ $0", "≈ $25"] },
];

function isPositive(v: string): boolean {
  return v === "yes" || v === "$0" || v === "none" || v.startsWith("per-app");
}

function isNegative(v: string): boolean {
  return v === "no" || v === "best effort";
}

interface PricingCardData {
  tag: string;
  title: string;
  priceSuffix: string;
  tagline: string;
  body: string;
  features: string[];
  cta: { href: string; label: string; external?: boolean };
}

const pricingCards: PricingCardData[] = [
  {
    tag: "free",
    title: "$0",
    priceSuffix: "/ forever",
    tagline: "edgepush.dev hosted",
    body: "No credit card. The fastest way to try edgepush against a real device. Sized for side projects and indie apps that haven't shipped yet.",
    cta: { href: "/sign-in", label: "$ sign_in_with_github" },
    features: ["1 app", "10K events / month", "7-day delivery log", "BYO apns + fcm credentials", "delivery receipts + webhooks", "support via github issues"],
  },
  {
    tag: "pro",
    title: "$29",
    priceSuffix: "/ month",
    tagline: "edgepush.dev hosted",
    body: "For indie shippers running a few apps in production. Same infrastructure as free, just with the room to actually use it. Priority email support direct from the operator.",
    cta: { href: "/pricing", label: "$ upgrade_to_pro" },
    features: ["3 apps", "50K events / month", "14-day delivery log", "everything in free, plus:", "priority email support", "credential health alerts"],
  },
  {
    tag: "self-host",
    title: "$0",
    priceSuffix: "/ forever",
    tagline: "your cloudflare account",
    body: "Same code, your infra, your data. Cloudflare's free tier covers most apps. You own the credentials, the rate limits, the deploy cadence. No edgepush.dev in the middle.",
    cta: { href: "/selfhost", label: "$ self_host_guide" },
    features: ["unlimited apps + events", "2 wrangler deploys to go live", "agpl-3.0 server source", "your D1, KV, queue, DO", "your apns + fcm credentials", "no telemetry, no operator"],
  },
];

interface FaqItemData {
  q: string;
  a: string;
}

const faqItems: FaqItemData[] = [
  { q: "I already have APNs and FCM credentials. Does edgepush use them?", a: "Yes, that's the whole point. Upload your existing .p8 key and Firebase service account JSON. edgepush encrypts and stores them. You keep full ownership." },
  { q: "How are my credentials protected?", a: "Encrypted with AES-GCM in a Cloudflare D1 row scoped to your app. The encryption key is a Worker secret, never in the database. The raw credential is never returned by the API after upload." },
  { q: "How do I migrate from Expo Push?", a: "Switch your app from getExpoPushTokenAsync to getDevicePushTokenAsync (one function name change), point your server at /v1/send. That's the entire migration. edgepush uses native APNs and FCM tokens, not Expo's proprietary wrapper." },
  { q: "What are the rate limits?", a: "1000 pushes per minute per app (configurable). Per-app token bucket via a Durable Object. Self-hosters can tune the limit to anything they want." },
  { q: "Do I need to store device tokens with edgepush?", a: "No. edgepush is a dispatch layer. You manage tokens in your own database. Each receipt tells you when a token is invalid so you can prune it." },
  { q: "Is this stable enough for production?", a: "v1.0 ships the full pipeline: send, dispatch, receipts, webhooks, credential health probes, nightly backups, Stripe billing, per-app rate limits, webhook retry queue, FCM topics. 70 unit tests. Semver from here." },
  { q: "Why does this run on Cloudflare?", a: "Workers + D1 + Queues + Durable Objects is the only stack where the entire push pipeline runs on free-tier edge primitives. No cold starts. No per-region routing. One runtime, globally." },
  { q: "What about web push or email?", a: "edgepush does native iOS and Android push. That's the scope. For multi-channel orchestration, use a dedicated tool alongside edgepush." },
];

const currentYear = new Date().getFullYear();

// Pre-render code panels as HTML strings (Astro's template doesn't handle
// nested .map() with ternary + Fragment well)
function renderCodePanel(panel: CodeLine): string {
  return panel.lines.map(line => {
    if (line.length === 0) return "\n";
    return line.map(([t, text]) => {
      const cls = tone(t);
      const escaped = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
      return cls ? `<span class="${cls}">${escaped}</span>` : escaped;
    }).join("") + "\n";
  }).join("");
}

const nodeTsHtml = renderCodePanel(nodeTsPanel);
const curlHtml = renderCodePanel(curlPanel);
const webhookHtml = renderCodePanel(webhookPanel);
