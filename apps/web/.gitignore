# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# .env.production holds NEXT_PUBLIC_API_URL which is inlined into the
# client bundle at build time. It must be committed so CF Workers Builds
# (and self-hosters' deploys) pick up the right value.
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
